PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskplanet?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary (https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — Set this to your Vercel frontend URL in production
# Leave blank for local dev (localhost:5173 is whitelisted by default)
CLIENT_URL=https://your-app-name.vercel.app
